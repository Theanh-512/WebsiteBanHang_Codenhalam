@model WebsiteBanHang.Models.Product

<div class="container mt-4 mb-5">
    <div class="row">
        <!-- Ảnh chính -->
        <div class="col-md-5 mb-4 text-center">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm border"
                     style="max-height: 400px; object-fit: contain;" />
            }
            else
            {
                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 400px;">
                    <span class="text-muted">Chưa có ảnh</span>
                </div>
            }

            <!-- Ảnh mô tả nhỏ bên dưới -->
            @if (Model.ImageUrls != null && Model.ImageUrls.Count > 0)
            {
                <div class="d-flex flex-wrap mt-3 justify-content-center gap-2">
                    @foreach (var img in Model.ImageUrls)
                    {
                        <img src="@img" class="img-thumbnail"
                             style="width: 80px; height: 80px; object-fit: cover; cursor: pointer;"
                             onclick="document.querySelector('.col-md-5 > img').src=this.src;" title="Nhấn để xem lớn" />
                    }
                </div>
            }
        </div>

        <!-- Chi tiết sản phẩm -->
        <div class="col-md-7">
            <h2 class="fw-bold mb-3">@Model.Name</h2>
            <h3 class="text-danger fw-bold mb-4">@Model.Price.ToString("N0") ₫</h3>
            
            <div class="card border-0 bg-light p-3 mb-4 rounded-3">
                <h5 class="fw-bold">Thông tin chi tiết</h5>
                <p style="white-space: pre-line;">@Model.Description</p>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Quay lại</a>
                <button class="btn btn-danger px-4 rounded-pill fw-bold"><i class="bi bi-cart-plus me-2"></i>Thêm vào
                    giỏ</button>
                </div>
            </div>
        </div>
    </div>
