@model IEnumerable<WebsiteBanHang.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-4">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card">
                    <a asp-action="Display" asp-route-id="@item.Id" class="text-decoration-none">
                        <div class="position-relative">
                           <img src="@item.ImageUrl" class="card-img-top p-3" style="height:220px; object-fit:contain;" alt="@item.Name" />
                        </div>
                        <div class="card-body px-3 pb-3 pt-0 text-center">
                            <h6 class="card-title text-dark fw-bold text-truncate-2 mb-2" style="height: 40px; font-size: 14px;">@item.Name</h6>
                            <p class="text-danger fw-bold fs-5 mb-3">
                                @item.Price.ToString("N0") ₫
                            </p>
                        </div>
                    </a>
                    <div class="px-3 pb-3">
                        <a asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@item.Id" 
                           class="btn btn-danger w-100 rounded-pill py-2 fw-bold small">
                            <i class="bi bi-cart-plus me-1"></i> THÊM VÀO GIỎ
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
