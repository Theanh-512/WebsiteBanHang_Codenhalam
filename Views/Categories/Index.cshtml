@model IEnumerable<WebsiteBanHang.Models.Category>

@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="container mt-4">
    <h2>Quản lý Danh mục</h2>
    <a asp-action="Add" class="btn btn-primary mb-3">Thêm Danh mục Mới</a>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên danh mục</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>
                        <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
