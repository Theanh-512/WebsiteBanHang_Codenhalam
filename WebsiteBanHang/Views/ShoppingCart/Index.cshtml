@model IEnumerable<WebsiteBanHang.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
    decimal total = 0;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index" class="text-danger text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Giỏ hàng của bạn</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white py-3 border-bottom overflow-hidden">
                    <h5 class="mb-0 fw-bold text-danger"><i class="bi bi-cart3 me-2"></i>Giỏ hàng (@Model.Count() sản phẩm)</h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-cart-x display-1 text-muted"></i>
                            <p class="mt-3 fs-5 text-muted">Giỏ hàng của bạn đang trống</p>
                            <a asp-controller="Product" asp-action="Index" class="btn btn-danger rounded-pill px-4 mt-2">Tiếp tục mua sắm</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4 py-3 border-0">Sản phẩm</th>
                                        <th class="py-3 border-0">Giá</th>
                                        <th class="py-3 border-0" style="width: 120px;">Số lượng</th>
                                        <th class="py-3 border-0">Thành tiền</th>
                                        <th class="py-3 border-0 pe-4 text-center">Xóa</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        var subtotal = item.Price * item.Quantity;
                                        total += subtotal;
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)" 
                                                         class="rounded-3 border" style="width: 60px; height: 60px; object-fit: cover;" alt="@item.Name">
                                                    <div class="ms-3">
                                                        <h6 class="mb-0 fw-bold text-dark text-truncate" style="max-width: 200px;">@item.Name</h6>
                                                        <small class="text-muted">Mã SP: @item.ProductId</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="py-3 fw-bold text-danger">@item.Price.ToString("N0")₫</td>
                                            <td class="py-3">
                                                <div class="d-flex align-items-center bg-light rounded-pill p-1" style="width: 110px;">
                                                    <a asp-action="UpdateQuantity" asp-route-productId="@item.ProductId" asp-route-quantity="@(item.Quantity - 1)" 
                                                       class="btn btn-sm btn-light rounded-circle border-0"><i class="bi bi-dash"></i></a>
                                                    
                                                    <input type="text" class="form-control form-control-sm text-center border-0 bg-transparent fw-bold" 
                                                           value="@item.Quantity" readonly style="width: 40px;">

                                                    <a asp-action="UpdateQuantity" asp-route-productId="@item.ProductId" asp-route-quantity="@(item.Quantity + 1)" 
                                                       class="btn btn-sm btn-light rounded-circle border-0"><i class="bi bi-plus"></i></a>
                                                </div>
                                            </td>
                                            <td class="py-3 fw-bold text-danger">@subtotal.ToString("N0")₫</td>
                                            <td class="py-3 pe-4 text-center">
                                                <a asp-action="RemoveFromCart" asp-route-productId="@item.ProductId" class="text-muted hover-danger">
                                                    <i class="bi bi-trash3 fs-5"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
            
            <a asp-controller="Product" asp-action="Index" class="text-danger text-decoration-none fw-bold">
                <i class="bi bi-arrow-left me-2"></i>Tiếp tục tìm thêm sản phẩm khác
            </a>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 80px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Tổng cộng</h5>
                    
                    <div class="d-flex justify-content-between mb-3 fs-6">
                        <span class="text-muted">Tạm tính:</span>
                        <span class="fw-bold">@total.ToString("N0")₫</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-4 fs-6">
                        <span class="text-muted">Phí vận chuyển:</span>
                        <span class="text-success fw-bold">Miễn phí</span>
                    </div>
                    
                    <hr class="dashed">
                    
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fs-5 fw-bold">Thành tiền:</span>
                        <span class="fs-4 fw-bold text-danger">@total.ToString("N0")₫</span>
                    </div>
                    
                    <a asp-action="Checkout" class="btn btn-danger w-100 py-3 fw-bold rounded-4 shadow-sm mb-3">
                        TIẾN HÀNH ĐẶT HÀNG
                    </a>
                    
                    <div class="bg-light p-3 rounded-3 small text-muted">
                        <i class="bi bi-info-circle me-1"></i> Mọi thông tin của bạn đều được bảo mật tuyệt đối.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-danger:hover {
        color: #d70018 !important;
    }
    .dashed {
        border-top: 1px dashed #dee2e6;
        opacity: 1;
    }
    .breadcrumb-item + .breadcrumb-item::before {
        content: ">";
    }
</style>
