@model IEnumerable<WebsiteBanHang.Models.Category>

<div class="dropdown me-2">
    <button class="btn btn-nav-custom btn-category dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-grid-3x3-gap-fill fs-5 text-white"></i>
        <span class="d-none d-md-inline text-white ms-1">Danh mục</span>
    </button>
    <ul class="dropdown-menu shadow border-0 rounded-3 mt-2">
        <li>
            <a class="dropdown-item py-2" asp-area="" asp-controller="Product" asp-action="Index">
                <i class="bi bi-list-stars me-2 text-danger"></i> Tất cả sản phẩm
            </a>
        </li>
        <li><hr class="dropdown-divider"></li>
        @foreach (var category in Model)
        {
            <li>
                <a class="dropdown-item py-2" asp-area="" asp-controller="Product" asp-action="Index" asp-route-categoryId="@category.Id">
                    <i class="bi bi-tag me-2 text-danger"></i> @category.Name
                </a>
            </li>
        }
    </ul>
</div>
