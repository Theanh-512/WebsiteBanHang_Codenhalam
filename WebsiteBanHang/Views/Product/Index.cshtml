@model IEnumerable<WebsiteBanHang.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-4">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-6 col-md-4 col-lg-3 mb-4 d-flex align-items-stretch">
                <div class="card w-100 border-0 shadow-sm rounded-4 overflow-hidden product-card bg-white">
                    <a asp-action="Display" asp-route-id="@item.Id" class="text-decoration-none">
                        <div class="p-2">
                           <img src="@item.ImageUrl" class="card-img-top rounded-4" style="height:240px; object-fit:contain;" alt="@item.Name" />
                        </div>
                        <div class="card-body px-3 pb-2 pt-0 text-center">
                            <h6 class="card-title text-dark fw-bold text-truncate-2 mb-2" style="height: 42px; font-size: 14px; line-height: 1.5;">@item.Name</h6>
                            <p class="text-danger fw-bold fs-5 mb-2">
                                @item.Price.ToString("N0") ₫
                            </p>
                        </div>
                    </a>
                    <div class="px-3 pb-3 mt-auto">
                        <a asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@item.Id" 
                           class="btn btn-danger w-100 rounded-3 py-2 fw-bold btn-add-to-cart">
                            <i class="bi bi-cart3 me-1"></i> THÊM VÀO GIỎ
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
