@model IEnumerable<WebsiteBanHang.Models.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0 fw-bold text-danger"><i class="bi bi-receipt me-2"></i>DANH SÁCH ĐƠN HÀNG</h4>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Mã ĐH</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Địa chỉ</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">#@item.Id.ToString("D6")</td>
                                <td>
                                    <div class="fw-bold">@item.ApplicationUser.FullName</div>
                                    <small class="text-muted">@item.ApplicationUser.Email</small>
                                </td>
                                <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-bold text-danger">@item.TotalPrice.ToString("N0")₫</td>
                                <td class="text-truncate" style="max-width: 200px;">@item.ShippingAddress</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                        <i class="bi bi-eye me-1"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
