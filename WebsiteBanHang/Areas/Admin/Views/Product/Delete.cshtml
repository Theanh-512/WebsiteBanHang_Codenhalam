@model WebsiteBanHang.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0 text-center"><i class="bi bi-exclamation-triangle-fill me-2"></i>Xác nhận xóa</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <p class="fs-5">Bạn có chắc chắn muốn xóa sản phẩm này không?</p>
                    <div class="my-4">
                        <img src="@Model.ImageUrl" class="rounded shadow-sm" style="max-height: 200px;" />
                        <h4 class="mt-3 fw-bold">@Model.Name</h4>
                        <p class="text-danger fw-bold">@Model.Price.ToString("#,##0") đ</p>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <button type="submit" class="btn btn-danger px-5">
                                <i class="bi bi-trash me-1"></i> Xóa ngay
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-5">
                                Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
