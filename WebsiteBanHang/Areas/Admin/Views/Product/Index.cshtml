@model IEnumerable<WebsiteBanHang.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="container-fluid">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-danger"><i class="bi bi-box-seam me-2"></i>Danh sách sản phẩm</h5>
            <a asp-action="Add" class="btn btn-danger btn-sm rounded-pill px-3">
                <i class="bi bi-plus-lg me-1"></i> Thêm sản phẩm mới
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Hình ảnh</th>
                            <th>Tên sản phẩm</th>
                            <th>Giá</th>
                            <th>Danh mục</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <img src="@item.ImageUrl" alt="@item.Name" class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover;" />
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.Name</div>
                                    <small class="text-muted">ID: #@item.Id</small>
                                </td>
                                <td>
                                    <span class="text-danger fw-bold">@item.Price.ToString("#,##0") đ</span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">@item.Category?.Name</span>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm rounded-circle me-1" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm rounded-circle" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
