@model IEnumerable<WebsiteBanHang.Areas.Admin.Controllers.UserRolesViewModel>

@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0 fw-bold text-danger"><i class="bi bi-people me-2"></i>DANH SÁCH NGƯỜI DÙNG</h4>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Họ và tên</th>
                            <th>Email</th>
                            <th>Vai trò</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@user.FullName</td>
                                <td>@user.Email</td>
                                <td>
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="badge bg-danger rounded-pill px-2" style="font-size: 11px;">@role</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-primary rounded-pill px-3 me-2">
                                            <i class="bi bi-pencil me-1"></i> Sửa
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@user.UserId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa người dùng này?');" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                <i class="bi bi-trash me-1"></i> Xóa
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
