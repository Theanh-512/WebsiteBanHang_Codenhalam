## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
## See https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/lib/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build log of MSBuild
*.unexpected.log

# Entity Framework 6 XML files
ModelResGen.obj
ModelResGen.xml
_UpgradeReport_Files/

# API Online help files
*.SourceCode.xml

# Offline collation files
*.swp
*~

# F# project builds
etf/

# OpenCover results
OpenCoverInternal.xml

# EF Core MySql (Pomelo)
*.pfx

# Application Insights config file
ApplicationInsights.config

# SQL Server files
*.mdf
*.ldf
*.ndf

# Other
.DS_Store
.directory
.gitattributes

# ASP.NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Visual Studio Code
.vscode/

# Rider
.idea/

# Local history for Visual Studio
.localhistory/

# Built-in app settings secrets
appsettings.json
appsettings.Development.json
