@model WebsiteBanHang.Models.Category

@{
    ViewData["Title"] = "Xóa danh mục";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white py-3 text-center">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Xác nhận xóa</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <p class="fs-5">Bạn có chắc chắn muốn xóa danh mục này không?</p>
                    <div class="alert alert-light border my-4">
                        <h4 class="fw-bold mb-0">@Model.Name</h4>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-center gap-3">
                            <button type="submit" class="btn btn-danger px-5 rounded-pill fw-bold">
                                <i class="bi bi-trash me-1"></i> Xóa ngay
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-5 rounded-pill">
                                Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
