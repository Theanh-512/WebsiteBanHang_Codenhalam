@model WebsiteBanHang.Models.Product

@{
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Cập nhật sản phẩm</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Update" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3 text-center">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" class="rounded shadow-sm img-thumbnail" style="max-height: 150px;" />
                                <p class="mt-2 small text-muted">Hình ảnh hiện tại</p>
                            }
                        </div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm</label>
                            <input asp-for="Name" class="form-control rounded-3" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Price" class="form-label fw-bold">Giá bán (VNĐ)</label>
                                    <input asp-for="Price" type="number" class="form-control rounded-3" />
                                    <span asp-validation-for="Price" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="CategoryId" class="form-label fw-bold">Danh mục</label>
                                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select rounded-3"></select>
                                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả sản phẩm</label>
                            <textarea asp-for="Description" class="form-control rounded-3" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageFile" class="form-label fw-bold">Thay đổi hình ảnh chính</label>
                            <input asp-for="ImageFile" type="file" class="form-control rounded-3" accept="image/*" />
                        </div>

                        <div class="mb-4">
                            <label asp-for="ImageFiles" class="form-label fw-bold">Thêm hình ảnh mô tả</label>
                            <input asp-for="ImageFiles" type="file" class="form-control rounded-3" multiple accept="image/*" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger px-4 rounded-pill fw-bold">
                                <i class="bi bi-save me-1"></i> Cập nhật
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
