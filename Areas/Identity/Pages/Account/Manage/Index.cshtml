@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-danger text-white rounded-top-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-person-lines-fill me-2"></i>Thông tin tài khoản</h4>
            </div>
            <div class="card-body p-4">
                <partial name="_StatusMessage" for="StatusMessage" />
                <form id="profile-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập" disabled />
                        <label asp-for="Username" class="form-label">Email / Tên đăng nhập</label>
                    </div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Số điện thoại" />
                        <label asp-for="Input.PhoneNumber" class="form-label">Số điện thoại</label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger text-sm"></span>
                    </div>
                    
                    <button id="update-profile-button" type="submit" class="btn btn-danger rounded-pill px-5 fw-bold"><i
                        class="bi bi-floppy me-2"></i>Lưu thay đổi</button>
                        <a asp-controller="Product" asp-action="Index"
                           class="btn btn-outline-secondary rounded-pill px-4 ms-2">Trở về</a>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
